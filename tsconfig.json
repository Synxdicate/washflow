{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    /* CRITICAL: This allows TS to understand the #types/ imports */
    "moduleResolution": "bundler", 
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    
    /* Required for 'path' and other Node built-ins */
    "esModuleInterop": true,
    "skipLibCheck": true, 

    /* Your existing path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "vite.config.ts"]
}