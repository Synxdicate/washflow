{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    
    /* CRITICAL: This allows TS to understand modern package.json "imports" and "#" paths */
    "moduleResolution": "bundler", 
    
    /* Essential for Vite + Vue */
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    
    /* Fixes the "path" import error in your config */
    "esModuleInterop": true, 
    "skipLibCheck": true,

    /* Your existing path mapping */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "vite.config.ts"]
}